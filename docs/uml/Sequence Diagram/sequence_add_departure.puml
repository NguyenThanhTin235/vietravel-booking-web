@startuml
title Sơ đồ Tuần tự - Thêm Lịch khởi hành
actor "Admin" as Admin
participant "Browser" as UI
participant "DepartureAdminApiController" as Controller
participant "DepartureService" as Service
participant "DepartureRepository" as Repository
database "Database" as DB

Admin -> UI: Điền thông tin Lịch khởi hành\n(Tour, Ngày, Số chỗ, Giá) & Submit
activate UI
UI -> Controller: POST /api/admin/departures (DepartureUpsertRequest)
activate Controller
Controller -> Service: create(req)
activate Service

Service -> Service: Validate Request Data\n(Tour tồn tại, Ngày hợp lệ)
Service -> Repository: save(Departure)
activate Repository
Repository -> DB: INSERT INTO departures
activate DB
DB --> Repository: Success
deactivate DB
Repository --> Service: Return saved Departure
deactivate Repository

Service --> Controller: Return DepartureAdminResponse
deactivate Service
Controller --> UI: 200 OK (Departure Details)
deactivate Controller
UI --> Admin: Hiển thị thông báo thành công
deactivate UI

@enduml
